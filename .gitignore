# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Virtual Environment
.venv/
venv/
ENV/
env/

# Environment Variables (IMPORTANT!)
.env
!.env.example

# IDE & Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Outputs (runtime artifacts)
outputs/
!outputs/.gitkeep
!outputs/json/.gitkeep
!outputs/csv/.gitkeep
!outputs/reports/.gitkeep
!outputs/artifacts/.gitkeep

# Playwright
playwright-report/
test-results/
.playwright/

# Database (IMPORTANT - jangan upload database!)
*.db
*.sqlite3
*.sqlite
*.db-journal
*.db-shm
*.db-wal

# Logs
logs/
*.log
*.log.*

# Docker
.docker/
docker-compose.override.yml

# Alembic
alembic/versions/__pycache__/

# Secrets & Credentials (IMPORTANT!)
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/
.secrets/

# Temporary files
tmp/
temp/
.tmp/
*.tmp
*.bak
*.swp
*~.nib

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Backup files
*.backup
*.old
*.orig

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Streamlit
.streamlit/secrets.toml

# Node modules (jika ada frontend)
node_modules/
npm-debug.log
yarn-error.log

# Compiled files
*.com
*.class
*.dll
*.exe
*.o
*.so

