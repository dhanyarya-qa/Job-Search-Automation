# ============================================================
# Ultimate Job Hunting ATS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME="Ultimate Job Hunting ATS"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-super-secret-key-min-32-chars-here
DEBUG=false

# --- Database ---
# PostgreSQL (production): postgresql+asyncpg://ats_user:ats_password@localhost:5432/job_hunting_ats
# SQLite (development): sqlite+aiosqlite:///./job_hunting_ats.db
DATABASE_URL=sqlite+aiosqlite:///./job_hunting_ats.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# --- AI Providers ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# --- Primary AI Provider (openai | anthropic | gemini) ---
PRIMARY_AI_PROVIDER=gemini

# --- Anti-Captcha ---
ANTICAPTCHA_API_KEY=your-anticaptcha-key

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_CHANNEL_ID=  # Optional: Channel ID (format: -100xxxxxxxxxx) to post jobs publicly

# --- JWT Auth ---
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OTP ---
OTP_SECRET_KEY=your-otp-secret-key
OTP_EXPIRE_MINUTES=5

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# --- Scraper ---
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY=5
SCRAPER_RATE_LIMIT_RPM=30
PROXY_LIST=  # comma-separated: http://user:pass@host:port

# --- Proxy ---
USE_PROXY=false

# --- Output ---
OUTPUT_DIR=./outputs
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501
FASTAPI_BASE_URL=http://localhost:8000

# --- Candidate Profile ---
CANDIDATE_NAME="Dhany Arya Pratama"
CANDIDATE_ROLE="QA Engineer | Prompt Engineer | AI Automation"
CANDIDATE_SKILLS="Playwright,Appium,Postman,API Testing,Selenium,Python,JavaScript"
